<service>
    <id>wolp-service</id>
    <name>wolp background service for Windows</name>
    <description>A backend-only service of wol plus.</description>
    <executable>%BASE%\wolp.exe</executable>
    <arguments>--backend-only</arguments>
    <env name="PATH" value="%BASE%\;%windir%\system32\"/>
    <workingdirectory>%BASE%</workingdirectory>
    <log mode="roll"></log>
    <onfailure action="restart" delay="10 sec"/>
</service>
