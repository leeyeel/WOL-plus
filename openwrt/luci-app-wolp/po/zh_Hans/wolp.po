msgstr "可选。为空时会回退到默认接口。"

msgid "Optional. Used for shutdown and reachability checks"
msgstr "可选。用于关机和连通性检测。"

msgid "Ping reachable with a known IPv4 address"
msgstr "具有已知 IPv4 且 Ping 可达"

