msgstr "當目前沒有可用主機提示時，關機必填"

msgid "Resolved from host hints"
msgstr "由主機提示解析"

msgid "Save"
msgstr "儲存"

msgid "Save Defaults"
msgstr "儲存預設設定"

msgid "Select at least one enabled device to wake."
msgstr "至少選擇一個已啟用裝置進行喚醒。"

msgid "Send to broadcast address"
msgstr "傳送到廣播位址"

msgid "Sending shutdown command…"
msgstr "正在傳送關機命令…"

msgid "Shutdown"
msgstr "關機"

msgid "Shutdown request sent"
msgstr "關機請求已送出"

msgid "Shutting down host"
msgstr "正在關閉主機"

msgid "Shutting down host failed"
msgstr "關閉主機失敗"

msgid "Starting WoL utility…"
msgstr "正在啟動網路喚醒工具…"

msgid "Status"
msgstr "狀態"

msgid "Stored IPv4 exists but ping probe failed"
msgstr "已儲存的 IPv4 存在，但 Ping 探測失敗"

