msgstr "編輯"

msgid "Edit Device"
msgstr "編輯裝置"

msgid "Enabled"
msgstr "啟用"

msgid "Enter a device name."
msgstr "請輸入裝置名稱。"

msgid "Enter a valid IPv4 address."
msgstr "請輸入有效的 IPv4 位址。"

msgid "Enter a valid MAC address."
msgstr "請輸入有效的 MAC 位址。"

msgid "Enter a valid UDP port."
msgstr "請輸入有效的 UDP 連接埠。"

