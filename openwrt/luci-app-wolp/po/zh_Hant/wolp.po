msgstr "成功"

msgid "The selected device does not have a valid MAC address."
msgstr "所選裝置沒有有效的 MAC 位址。"

msgid "These values prefill new devices and manual operations. Device-level values override defaults."
msgstr "這些值會預填新裝置和手動操作；裝置層級設定會覆蓋預設值。"

msgid "UDP Port"
msgstr "UDP 連接埠"

msgid "Unknown"
msgstr "未知"

msgid "Use this panel for one-off operations or to prefill fields from a configured device."
msgstr "使用此面板執行一次性操作，或從已設定裝置預填欄位。"

msgid "Used only for wake requests"
msgstr "僅用於喚醒請求"

msgid "Wake"
msgstr "喚醒"

msgid "Wake Interface"
msgstr "喚醒介面"

msgid "Wake Selected"
msgstr "喚醒所選"

msgid "Wake on LAN Plus"
msgstr "網路喚醒+"

msgid "Waking host"
msgstr "正在喚醒主機"

msgid "Waking host failed"
msgstr "喚醒主機失敗"

msgid "Waking selected devices"
msgstr "正在喚醒所選裝置"

msgid "etherwake is not installed!"
msgstr "etherwake 未安裝！"

msgid "netcat is not installed!"
msgstr "netcat 未安裝！"
